{
  "manifest_version": 3,
  "name": "BRunner",
  "version": "2.2.0",
  "description": "Enterprise-grade event-driven browser automation engine.",

  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage",
    "sidePanel",
    "debugger",
    "search"
  ],

  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "ws://127.0.0.1:8999/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_title": "BRunner"
  },

  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },

  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content/targetResolver.js",
        "content/mapper.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "studio/index.html",
        "studio/app.js",
        "studio/style.css",
        "sidebar/sidebar.html",
        "sidebar/sidebar.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
