{
  "name": "[NEW 2026-07-02] Clipboard Acceptance",
  "description": "Fresh host-served acceptance workflow. Opens the harness, writes clipboard text, reads it back, and types it into Account name.",
  "tags": ["new-2026-07-02", "host-served-8765", "acceptance"],
  "boundDomain": "http://127.0.0.1:8765/test.html",
  "variables": {},
  "settings": {
    "reuseExistingTabs": false
  },
  "steps": [
    {
      "id": "clipboard_acceptance_open",
      "action": "browser.navigate",
      "url": "http://127.0.0.1:8765/test.html",
      "friendlyName": "Open host-served acceptance page"
    },
    {
      "id": "clipboard_acceptance_write",
      "action": "clipboard.write",
      "config": {
        "value": "BRunner clipboard acceptance",
        "variableName": "clipboard_write_result"
      },
      "friendlyName": "Write clipboard text"
    },
    {
      "id": "clipboard_acceptance_read",
      "action": "clipboard.read",
      "config": {
        "allowClipboardRead": "allow",
        "variableName": "clipboard_text"
      },
      "friendlyName": "Read clipboard text"
    },
    {
      "id": "clipboard_acceptance_visible_output",
      "action": "element.type",
      "target": {
        "strategy": "id",
        "value": "name-input"
      },
      "config": {
        "value": "{{clipboard_text}}",
        "verificationText": "BRunner clipboard acceptance"
      },
      "friendlyName": "Type clipboard output into Account name"
    }
  ]
}
