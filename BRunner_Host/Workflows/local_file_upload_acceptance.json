{
  "name": "[NEW 2026-07-02] Local File Upload Acceptance",
  "description": "Fresh host-served acceptance workflow. Reads an allowlisted local file through the native host and uploads it to the page.",
  "tags": ["new-2026-07-02", "host-served-8765", "acceptance"],
  "boundDomain": "http://127.0.0.1:8765/test.html",
  "variables": {},
  "settings": {
    "reuseExistingTabs": false
  },
  "steps": [
    {
      "id": "local_file_acceptance_open",
      "action": "browser.navigate",
      "url": "http://127.0.0.1:8765/test.html",
      "friendlyName": "Open host-served acceptance page"
    },
    {
      "id": "local_file_acceptance_upload",
      "action": "file.local.upload",
      "target": {
        "strategy": "id",
        "value": "upload-file"
      },
      "config": {
        "allowLocalFileRead": "allow",
        "path": "AllowedFiles/local-upload-acceptance.txt",
        "variableName": "local_file_result"
      },
      "friendlyName": "Upload allowlisted local acceptance file"
    }
  ]
}
