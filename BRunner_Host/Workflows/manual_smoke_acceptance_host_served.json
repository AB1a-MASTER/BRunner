{
  "name": "[NEW 2026-07-02] Manual Smoke Acceptance Host Served",
  "description": "Fresh host-served acceptance workflow. Duplicate smoke workflow with an explicit host-served name for manual testing.",
  "tags": ["new-2026-07-02", "host-served-8765", "acceptance"],
  "boundDomain": "http://127.0.0.1:8765/test.html",
  "variables": {},
  "settings": {
    "reuseExistingTabs": false
  },
  "steps": [
    {
      "id": "host_smoke_open",
      "action": "browser.navigate",
      "url": "http://127.0.0.1:8765/test.html",
      "friendlyName": "Open host-served acceptance page"
    },
    {
      "id": "host_smoke_type_account_name",
      "action": "element.type",
      "target": {
        "strategy": "id",
        "value": "name-input"
      },
      "config": {
        "value": "BRunner host smoke",
        "verificationText": "BRunner host smoke"
      },
      "friendlyName": "Type account name"
    },
    {
      "id": "host_smoke_select_country",
      "action": "element.select",
      "target": {
        "strategy": "id",
        "value": "country"
      },
      "config": {
        "value": "Pakistan"
      },
      "friendlyName": "Select country"
    },
    {
      "id": "host_smoke_accept_terms",
      "action": "element.toggle",
      "target": {
        "strategy": "id",
        "value": "agree"
      },
      "config": {
        "value": true
      },
      "friendlyName": "Accept terms"
    },
    {
      "id": "host_smoke_submit",
      "action": "element.click",
      "target": {
        "strategy": "id",
        "value": "result-button"
      },
      "config": {
        "verificationSelector": "#status",
        "verificationText": "Submit Test clicked"
      },
      "friendlyName": "Submit acceptance form"
    }
  ]
}
