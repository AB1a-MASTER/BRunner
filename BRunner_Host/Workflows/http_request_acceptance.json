{
  "name": "[NEW 2026-07-02] HTTP Request Acceptance",
  "description": "Fresh host-served acceptance workflow. Fetches a local JSON fixture and types a value from the response into Account name.",
  "tags": ["new-2026-07-02", "host-served-8765", "acceptance"],
  "boundDomain": "http://127.0.0.1:8765/test.html",
  "variables": {},
  "settings": {
    "reuseExistingTabs": false
  },
  "steps": [
    {
      "id": "http_acceptance_open",
      "action": "browser.navigate",
      "url": "http://127.0.0.1:8765/test.html",
      "friendlyName": "Open host-served acceptance page"
    },
    {
      "id": "http_acceptance_request",
      "action": "http.request",
      "config": {
        "method": "GET",
        "url": "http://127.0.0.1:8765/tests/fixtures/http-response.json",
        "headers": "{}",
        "body": "",
        "bodyType": "auto",
        "responseType": "json",
        "timeoutMs": 5000,
        "httpErrorPolicy": "fail",
        "variableName": "http_result"
      },
      "friendlyName": "Fetch local JSON fixture"
    },
    {
      "id": "http_acceptance_visible_output",
      "action": "element.type",
      "target": {
        "strategy": "id",
        "value": "name-input"
      },
      "config": {
        "value": "{{http_result.data.source}}",
        "verificationText": "BRunner live acceptance"
      },
      "friendlyName": "Type HTTP response source into Account name"
    }
  ]
}
