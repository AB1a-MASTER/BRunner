{
  "name": "[NEW 2026-07-02] Download Wait Acceptance",
  "description": "Fresh host-served acceptance workflow. Starts a fixture download, waits for it, and types the safe filename metadata into Account name.",
  "tags": ["new-2026-07-02", "host-served-8765", "acceptance"],
  "boundDomain": "http://127.0.0.1:8765/test.html",
  "variables": {},
  "settings": {
    "reuseExistingTabs": false
  },
  "steps": [
    {
      "id": "download_acceptance_open",
      "action": "browser.navigate",
      "url": "http://127.0.0.1:8765/test.html",
      "friendlyName": "Open host-served acceptance page"
    },
    {
      "id": "download_acceptance_click",
      "action": "element.click",
      "target": {
        "strategy": "id",
        "value": "download-fixture"
      },
      "friendlyName": "Download acceptance fixture"
    },
    {
      "id": "download_acceptance_wait",
      "action": "download.wait",
      "config": {
        "filenameContains": "download-acceptance",
        "urlContains": "/tests/fixtures/download-acceptance.txt",
        "timeoutMs": 10000,
        "startedWithinMs": 15000,
        "dangerPolicy": "fail",
        "variableName": "download_result"
      },
      "friendlyName": "Wait for fixture download"
    },
    {
      "id": "download_acceptance_visible_output",
      "action": "element.type",
      "target": {
        "strategy": "id",
        "value": "name-input"
      },
      "config": {
        "value": "{{download_result.filename}}",
        "verificationText": "download-acceptance"
      },
      "friendlyName": "Type download filename into Account name"
    }
  ]
}
