{
  "name": "[NEW 2026-07-02] Screenshot Capture Acceptance",
  "description": "Fresh host-served acceptance workflow. Opens the harness, captures a PNG screenshot, and types the saved filename into Account name.",
  "tags": ["new-2026-07-02", "host-served-8765", "acceptance"],
  "boundDomain": "http://127.0.0.1:8765/test.html",
  "variables": {},
  "settings": {
    "reuseExistingTabs": false
  },
  "steps": [
    {
      "id": "screenshot_acceptance_open",
      "action": "browser.navigate",
      "url": "http://127.0.0.1:8765/test.html",
      "friendlyName": "Open host-served acceptance page"
    },
    {
      "id": "screenshot_acceptance_capture",
      "action": "screenshot.capture",
      "config": {
        "format": "png",
        "quality": 90,
        "outputMode": "download",
        "filename": "brunner-acceptance.png",
        "variableName": "screenshot_result"
      },
      "friendlyName": "Capture acceptance screenshot"
    },
    {
      "id": "screenshot_acceptance_visible_output",
      "action": "element.type",
      "target": {
        "strategy": "id",
        "value": "name-input"
      },
      "config": {
        "value": "{{screenshot_result.filename}}",
        "verificationText": "brunner-acceptance"
      },
      "friendlyName": "Type screenshot filename into Account name"
    }
  ]
}
